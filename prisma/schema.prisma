generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shared table from Activity Logging app (read-only for auth)
model CrewMember {
  id           String   @id @default(uuid()) @db.Uuid
  firstName    String   @map("first_name")
  lastName     String?  @map("last_name")
  phone        String   @unique
  passwordHash String?  @map("password_hash")
  role         CrewRole
  isPrimary    Boolean  @default(true) @map("is_primary")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("crew_members")
}

enum CrewRole {
  LEAD_CAPTAIN
  CO_CAPTAIN
  EMOTIONAL_SUPPORT
}

// Boat Maintenance models

enum IssueStatus {
  OPEN
  IN_PROCESS
  CLOSED
  NON_ISSUE
  RE_OPENED
}

enum HandleBy {
  INTERNAL
  SERVICE_PROVIDER
}

enum IssueSeverity {
  CRITICAL
  WARNING
  INFO
}

model MaintenanceIssue {
  id           String      @id @default(uuid()) @db.Uuid
  description  String      @db.Text
  status       IssueStatus   @default(OPEN)
  severity     IssueSeverity @default(INFO)
  handleBy     HandleBy      @default(INTERNAL) @map("handle_by")
  dateOpened   DateTime    @default(now()) @map("date_opened")
  lastModified DateTime    @updatedAt @map("last_modified")
  sourceLogId  String?     @map("source_log_id") @db.Uuid

  @@map("maintenance_issues")
}

model FuelingRecord {
  id          String   @id @default(uuid()) @db.Uuid
  amount      Float
  engineHours Float?   @map("engine_hours")
  date        DateTime @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("fueling_records")
}

model MaintenanceAppUser {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  phone        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("maintenance_app_users")
}
